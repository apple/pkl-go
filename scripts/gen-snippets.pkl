extends "pkl:Command"

import "pkl:reflect"
import "pkl:test"

import "../codegen/src/gen.pkl"

local const lineNoRegex = Regex(#"(?m)^(( ║ )*)(\d+) \|"#)

local codegenDir =
  reflect
    .Module(gen)
    .uri
    .replaceAll(Regex("^file:(//)?"), "")
    .split("/")
    .dropLast(2)
    .add("snippet-tests")
    .join("/")

local run = (gen) {
  options {
    `base-path` = "github.com/apple/pkl-go"
    pklInputModules {
      for (_, mod in import*("../codegen/snippet-tests/input/*.pkl")) {
        mod
      }
    }
  }
  generateFilesForInput = (input, settings) ->
    let (inputUri = reflect.Module(input).uri)
      if (!inputUri.endsWith(".err.pkl"))
        gen.generateFilesForInput.apply(input, settings)
      else
        let (filename = inputUri.split("/").last)
        let (
          genError =
            test.catchOrNull(() -> gen.generateFilesForInput.apply(input, settings).toString())
        )
          if (genError == null)
            throw("Expected \(filename) to error, but it did not")
          else
            new Mapping<String, FileOutput> {
              // drop .pkl so it's just .err
              ["\(options.`output-path` ?? gen.pwd)/codegen/snippet-tests/output/\(filename.dropLast(4))"] {
                text =
                  genError
                    // replace absolute paths for consistency
                    .replaceAll(codegenDir, "<codegen_dir>")
                    // replace line numbers with the same amount of the letter "x" (to preserve formatting).
                    .replaceAllMapped(lineNoRegex, (match) ->
                      "x".repeat(match.value.length - 2) + " |"
                    )
              }
            }
}

output = run.output
