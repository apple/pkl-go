extends "pkl:Command"

import "pkl:pklbinary"

import "../codegen/src/gen.pkl"

local collections = import("../pkl/test_fixtures/collections.pkl")

local run = (gen) {
  options {
    `base-path` = "github.com/apple/pkl-go"
    pklInputModules {
      for (_, mod in import*("../pkl/test_fixtures/*.pkl")) {
        mod
      }
    }
  }
}

output {
  files {
    ...?run.output.files
    for (path, mod in import*("pklgo:/pkl/test_fixtures/*.pkl")) {
      ["pkl/test_fixtures/msgpack/\(path.split("/").last).msgpack"] {
        bytes = new pklbinary.Renderer {}.renderDocument(mod)
      }
    }
    for (prop in List("res1", "res2", "res9")) {
      ["pkl/test_fixtures/msgpack/collections.\(prop).msgpack"] {
        bytes = new pklbinary.Renderer {}.renderValue(collections.getProperty(prop))
      }
    }
  }
}
